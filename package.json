{
  "name": "tradgio",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\" \"scripts/**/*.mjs\" \"*.{js,json,ts}\" \".github/**/*.yml\" --write",
    "format:check": "prettier \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\" \"scripts/**/*.mjs\" \"*.{js,json,ts}\" \".github/**/*.yml\" --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:pwa": "npm run build && playwright test --config playwright.pwa.config.ts",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "build": "tsc --noEmit && vite build && node scripts/generate-pwa-assets.mjs",
    "audit": "npm audit --audit-level=moderate",
    "quality": "npm run lint && npm run format:check && npm run typecheck && npm run test && npm run build && npm run audit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.14",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "exceljs": {
      "uuid": "11.1.1"
    }
  }
}
